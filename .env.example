# Django Backend Configuration
#
# --- Going live (production) ---
# - Deploying pushes CODE only. Your production database keeps existing centre (franchise)
#   and parent logins; normal deploys do not overwrite them.
# - An admin user you created locally exists only in your LOCAL database. Production has
#   its own DB: use the admin account that already exists on live.
# - Set PUBLIC_SITE_URL, CSRF_TRUSTED_ORIGINS, DJANGO_ALLOWED_HOSTS, SENDGRID_API_KEY, etc.
#   to your real domain before going live.

# Security
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True

# Allowed Hosts (comma-separated)
# Keep this strict in production (do not use *)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS / CSRF Trusted Origins (comma-separated)
# Add every frontend origin that should be allowed.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com

# Database — PostgreSQL (settings.py reads these via os.getenv).
# Same server as Django: DB_HOST=127.0.0.1  |  Remote DB only: DB_HOST=<postgres-server-ip>
# Optional: DB_ENGINE=sqlite3 uses db.sqlite3 under this project folder instead.
#
# Use LIVE production data locally (read centres/cities from production):
#   DB_HOST=<live-server-ip-or-hostname>
#   DB_NAME=<live-db-name>
#   DB_USER=<live-db-user>
#   DB_PASSWORD=<live-db-password>
#   DB_PORT=5432
# Then restart Django. Frontend: set NEXT_PUBLIC_API_URL to your API (local proxy or live).
# Warning: do not run destructive migrations against production from a dev machine.
DB_ENGINE=postgresql
DB_NAME=time4kids
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONNECT_TIMEOUT=30

# JWT Token Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# Email Configuration (Optional — used only if SENDGRID_API_KEY is empty)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=info@timekidspreschools.com

# --- SendGrid (ONE account for everything) ---
# Same key + from-address as landing PHP pages.
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=info@timekidspreschools.com
MAIL_FROM_ADDRESS=info@timekidspreschools.com

# All admission/landing/register forms — sender + team alerts + thank-you CC:
MAIL_TO_ADDRESS=info@timekidspreschools.com
MAIL_LANDING_CC=info@timekidspreschools.com

# Franchise opportunity form only — internal alerts (sender stays info@):
MAIL_FRANCHISE_TO_ADDRESS=franchise@timekidspreschools.com
# One head for all zones + one head for all regions (new-lead reminder: name + source)
CRM_ZONAL_HEAD_EMAIL=
CRM_REGIONAL_HEAD_EMAIL=

# Links in password-reset emails (register + forgot password)
PUBLIC_SITE_URL=https://www.timekidspreschools.in

# Centre PDFs/ZIPs — default is <repo-root>/pc/ (see pc/README.md).
# Leave empty to use ../pc next to time4kidsbe. Override only if files live elsewhere.
# PC_DOCUMENTS_ROOT=

# Public-site brochures served from pc/ via /media/pc/... (see set_marketing_brochure_from_pc)
# ADMISSION_BROCHURE_PC_PATH=admission-brochure/admission-brochure.pdf
# FRANCHISE_BROCHURE_PC_PATH=franchise-brochure/franchise-brochure.pdf

# Import pc/ into PostgreSQL (optional; links still work via /media/pc/ without import):
#   python manage.py import_pc_documents
#   python manage.py import_pc_documents --update

# --- Legacy TiKES fee database (optional — parent fee view reads fee_payment / fee_amt_paid) ---
# When set, parent /dashboard/parent/fees shows live legacy fee data by student ID card number.
# LEGACY_FEE_DB_HOST=103.65.21.245
# LEGACY_FEE_DB_NAME=tikesin_bms
# LEGACY_FEE_DB_USER=tikesin_dev
# LEGACY_FEE_DB_PASSWORD=
# LEGACY_FEE_DB_PORT=3306

# --- PLP / TiKES enrollment push (POST /api/plp/create-enrollment/) ---
# TiKES sends new parent data here when fee is paid. Header: X-API-Key
# PLP_API_KEY=your-long-random-secret-here

# --- Parent fee UPI QR (Pay Now in parent app) ---
# Your UPI ID for fee collection (e.g. merchant@oksbi). Parents scan QR and pay; they tap confirm in the app.
# PARENT_FEE_UPI_VPA=yourname@upi
# PARENT_FEE_UPI_PAYEE_NAME=T.I.M.E. Kids Domalaguda
# Optional: upload your QR to Next public/ and set full URL (overrides auto-generated UPI QR):
# PARENT_FEE_QR_IMAGE_URL=http://localhost:3000/fees/payment-qr.png
# When using a static QR image, set the amount encoded in that QR (e.g. 1 for ₹1 test payments):
# PARENT_FEE_QR_FIXED_AMOUNT=1
