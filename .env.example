# Django Backend Configuration
#
# --- Going live (production) ---
# - Deploying pushes CODE only. Your production database keeps existing centre (franchise)
#   and parent logins; normal deploys do not overwrite them.
# - An admin user you created locally exists only in your LOCAL database. Production has
#   its own DB: use the admin account that already exists on live.
# - Set PUBLIC_SITE_URL, CSRF_TRUSTED_ORIGINS, DJANGO_ALLOWED_HOSTS, SENDGRID_API_KEY, etc.
#   to your real domain before going live.

# Security
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True

# Allowed Hosts (comma-separated)
# Keep this strict in production (do not use *)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS / CSRF Trusted Origins (comma-separated)
# Add every frontend origin that should be allowed.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com

# Database — PostgreSQL is the default (local + development + production).
# Create DB: CREATE DATABASE time4kids;
# Optional: DB_ENGINE=sqlite3 uses db.sqlite3 under this project folder instead.
DB_ENGINE=postgresql
DB_NAME=time4kids
DB_USER=postgres
DB_PASSWORD=
# Use 127.0.0.1 on Windows if IPv6 (::1) causes connection issues.
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT Token Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@time4kids.app

# SendGrid API key (required for parent announcement emails; same as career/enquiry mail)
SENDGRID_API_KEY=

# Frontend public URL used in emails and reset links
PUBLIC_SITE_URL=https://your-domain.com
