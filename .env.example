# Django Backend Configuration
#
# --- Going live (production) ---
# - Deploying pushes CODE only. Your production database keeps existing centre (franchise)
#   and parent logins; normal deploys do not overwrite them.
# - An admin user you created locally exists only in your LOCAL database. Production has
#   its own DB: sign in with the admin already on live, OR run create_site_admin once on
#   the server (see below) if that server still needs a head-office admin.
# - Set PUBLIC_SITE_URL, CSRF_TRUSTED_ORIGINS, DJANGO_ALLOWED_HOSTS, SENDGRID_API_KEY, etc.
#   to your real domain before going live.

# Security
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True

# Allowed Hosts (comma-separated)
# For local network access, add your local IP (e.g., 192.168.1.100)
# For public access, add your public IP or domain
DJANGO_ALLOWED_HOSTS=*

# CORS & CSRF Trusted Origins (comma-separated)
# Add your frontend URLs here
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Token Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# Email Configuration (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@time4kids.app

# SendGrid API key (required for parent announcement emails; same as career/enquiry mail)
SENDGRID_API_KEY=

# Frontend URL used in announcement emails (link to parent Notifications page)
PUBLIC_SITE_URL=http://localhost:3000

# Optional — only if THIS production server has no admin yet (never touches franchise/parent rows):
#   set DJANGO_CREATE_ADMIN_PASSWORD=...  then
#   python manage.py create_site_admin --email your-admin@company.com
# Skip if you already have an admin on live.
